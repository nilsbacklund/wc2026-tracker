# Backend secrets — copy to .env (gitignored) and fill in. The backend loads
# .env automatically (backend/wc2026_backend/config.py). Deploy platforms can
# set these as real env vars instead; those take precedence over .env.

# Supabase Postgres connection string (Dashboard → Project Settings → Database
# → Connection string → URI). When set, the backend + CLI use Supabase instead
# of local SQLite. Contains your DB password — never commit the real value.
SUPABASE_DB_URL=

# football-data.org v4 token for authoritative full-time results (optional;
# ESPN provides live scores without any key).
FOOTBALL_DATA_TOKEN=

# Set to any value to stop the backend from auto-starting the live ESPN poller.
WC2026_DISABLE_POLLER=
